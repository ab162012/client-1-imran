{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A perfume product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name", "price", "description", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "city": { "type": "string" }
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["customer", "products", "total", "status", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of perfume products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users and their roles"
    }
  }
}
