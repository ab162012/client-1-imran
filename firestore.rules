rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email in ["abdulbasit162012@gmail.com", "infoperfumeenclave@gmail.com"]);
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'price', 'original_price', 'description', 'image', 'images', 'notes', 'usage', 'views', 'featured', 'createdAt', 'discount', 'reviewCount', 'sizePrices', 'category', 'badge', 'priority']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price > 0 &&
             (!('original_price' in data) || (data.original_price is number && data.original_price > 0)) &&
             data.description is string && data.description.size() < 2000 &&
             data.image is string &&
             (!('images' in data) || data.images is list) &&
             data.notes is list && data.notes.size() < 20 &&
             data.usage is string && data.usage.size() < 500 &&
             (!('views' in data) || (data.views is number && data.views >= 0)) &&
             (!('featured' in data) || (data.featured is bool)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt is number)) &&
             (!('discount' in data) || (data.discount is number)) &&
             (!('reviewCount' in data) || (data.reviewCount is number)) &&
             (!('sizePrices' in data) || (data.sizePrices is map)) &&
             (!('category' in data) || (data.category is string)) &&
             (!('badge' in data) || (data.badge is string)) &&
             (!('priority' in data) || (data.priority is number));
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['customer', 'products', 'total', 'status', 'timestamp', 'createdAt']) &&
             data.customer is map &&
             data.customer.name is string && data.customer.name.size() > 0 &&
             data.customer.phone is string && data.customer.phone.size() >= 10 &&
             data.customer.address is string && data.customer.address.size() > 5 &&
             data.customer.city is string && data.customer.city.size() > 0 &&
             data.products is list && data.products.size() > 0 && data.products.size() < 20 &&
             data.total is number && data.total > 0 &&
             data.status == 'pending' &&
             data.timestamp == request.time;
    }

    function isValidReview(data) {
      return hasOnlyAllowedFields(['productId', 'customerName', 'rating', 'comment', 'status', 'createdAt', 'verified']) &&
             data.productId is string &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt is number)) &&
             (!('verified' in data) || data.verified is bool);
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['websiteName', 'logo', 'primaryColor', 'footerText', 'instagramUrl', 'facebookUrl', 'heroProductId']) &&
             data.websiteName is string &&
             data.logo is string &&
             data.primaryColor is string &&
             data.footerText is string &&
             data.instagramUrl is string &&
             data.facebookUrl is string &&
             data.heroProductId is string;
    }

    match /stores/{storeId} {
      match /products/{productId} {
        allow read: if true;
        allow create: if isAdmin() && isValidProduct(request.resource.data);
        allow update: if (isAdmin() && isValidProduct(request.resource.data)) || 
                        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
        allow delete: if isAdmin();
      }

      match /orders/{orderId} {
        allow create: if isValidOrder(request.resource.data);
        allow read, update, delete: if isAdmin();
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isValidReview(request.resource.data);
        allow update, delete: if isAdmin();
      }

      match /settings/{settingId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Legacy paths (keeping for backward compatibility during migration if needed, or remove if fully migrated)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
