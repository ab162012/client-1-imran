rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['customer', 'products', 'total', 'status', 'timestamp', 'createdAt']) &&
             data.customer is map &&
             data.customer.name is string && data.customer.name.size() > 0 &&
             data.customer.phone is string && data.customer.phone.size() >= 10 &&
             data.customer.address is string && data.customer.address.size() > 5 &&
             data.customer.city is string && data.customer.city.size() > 0 &&
             data.products is list && data.products.size() > 0 && data.products.size() < 20 &&
             data.total is number && data.total > 0 &&
             data.status == 'pending' &&
             data.timestamp == request.time;
    }

    function isValidReview(data) {
      return hasOnlyAllowedFields(['productId', 'customerName', 'rating', 'comment', 'status', 'createdAt', 'verified']) &&
             data.productId is string &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is number &&
             (!('verified' in data) || data.verified is bool);
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['websiteName', 'logo', 'primaryColor', 'footerText', 'instagramUrl', 'facebookUrl', 'heroProductId']) &&
             data.websiteName is string &&
             data.logo is string &&
             data.primaryColor is string &&
             data.footerText is string &&
             data.instagramUrl is string &&
             data.facebookUrl is string &&
             data.heroProductId is string;
    }

    function isAdmin() {
      return request.auth != null && 
             'email' in request.auth.token &&
             (request.auth.token.email.lower() == 'admin@perfumeenclave.com' ||
              request.auth.token.email.lower() == 'abdulbasit162012@gmail.com' ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.price is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
      allow update: if (isAdmin() && isValidProduct(request.resource.data)) || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
        (resource.data.views == null || request.resource.data.views == resource.data.views + 1)
      );
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
