rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function isValidOrder(data) {
      return hasOnlyAllowedFields(['customer', 'products', 'total', 'status', 'timestamp', 'createdAt']) &&
             data.customer is map &&
             data.customer.name is string && data.customer.name.size() > 0 &&
             data.customer.phone is string && data.customer.phone.size() >= 10 &&
             data.customer.address is string && data.customer.address.size() > 5 &&
             data.customer.city is string && data.customer.city.size() > 0 &&
             data.products is list && data.products.size() > 0 && data.products.size() < 20 &&
             data.total is number && data.total > 0 &&
             data.status == 'pending' &&
             data.timestamp == request.time;
    }

    function isValidReview(data) {
      return hasOnlyAllowedFields(['productId', 'customerName', 'rating', 'comment', 'status', 'createdAt', 'verified']) &&
             data.productId is string &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.status is string && data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is number &&
             (!('verified' in data) || data.verified is bool);
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['websiteName', 'logo', 'primaryColor', 'footerText', 'instagramUrl', 'facebookUrl', 'heroProductId']) &&
             data.websiteName is string &&
             data.logo is string &&
             data.primaryColor is string &&
             data.footerText is string &&
             data.instagramUrl is string &&
             data.facebookUrl is string &&
             data.heroProductId is string;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'abdulbasit162012@gmail.com' || 
              request.auth.token.email == 'admin@perfumeenclave.com');
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'price', 'original_price', 'description', 'image', 'images', 'notes', 'usage', 'stock', 'totalStock', 'soldQuantity', 'lowStockThreshold', 'views', 'stockStatus', 'featured', 'createdAt', 'discount', 'sizePrices', 'category', 'badge']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             (!('original_price' in data) || (data.original_price is number)) &&
             data.description is string && data.description.size() < 5000 &&
             data.image is string &&
             (!('images' in data) || data.images is list) &&
             (!('notes' in data) || data.notes is list) &&
             (!('usage' in data) || data.usage is string) &&
             (!('stock' in data) || (data.stock is number)) &&
             (!('totalStock' in data) || (data.totalStock is number)) &&
             (!('soldQuantity' in data) || (data.soldQuantity is number)) &&
             (!('lowStockThreshold' in data) || (data.lowStockThreshold is number)) &&
             (!('views' in data) || (data.views is number)) &&
             (!('stockStatus' in data) || (data.stockStatus is string)) &&
             (!('featured' in data) || (data.featured is bool)) &&
             (!('createdAt' in data) || (data.createdAt is number)) &&
             (!('discount' in data) || (data.discount is number)) &&
             (!('sizePrices' in data) || (data.sizePrices is map)) &&
             (!('category' in data) || (data.category is string)) &&
             (!('badge' in data) || (data.badge is string));
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /test/{docId} {
      allow read: if true;
    }
  }
}
